{
  "mcpServers": {
    "agentmux": {
      "command": "agentmux",
      "args": [
        "host", "mcp",
        "--bundle", "{{ project_bundle_name }}"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [ "-y", "@upstash/context7-mcp" ]
    },
    "nb": {
      "command": "nb-mcp",
      "args": [
        "--notebook", "{{ project_name }}",
        "--no-commit-signing"
      ]
    }
  }
}
